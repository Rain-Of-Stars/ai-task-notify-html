# AI Task Notify 配置文件
# 复制此文件为 .env 并填写你的邮件通知配置
# cp .env.example .env

# ============ 启用的通知渠道 ============
# 可选值: email
NOTIFY_CHANNELS=email

# ============ 邮件 (Email) ============
# 邮件安全等级:
# - open: 允许任意收件人（仅建议测试）
# - self: 仅允许发给自己（单收件人且与发件人一致）
# - self-strict: 在 self 基础上要求 SSL + 安全端口
EMAIL_SECURITY_LEVEL=self-strict
# 收件人白名单（可选，多个逗号分隔）
EMAIL_ALLOWED_RECIPIENTS=
# SMTP 服务器地址
SMTP_HOST=smtp.example.com
# SMTP 端口 (SSL通常为465，STARTTLS通常为587)
SMTP_PORT=465
# SMTP 登录用户名
SMTP_USER=your_email@example.com
# SMTP 登录密码或授权码
SMTP_PASSWORD=your_password_or_auth_code
# 是否使用SSL (true/false)
SMTP_USE_SSL=true
# 发件人地址
EMAIL_FROM=your_email@example.com
# 收件人地址 (多个用逗号分隔)
EMAIL_TO=recipient@example.com
